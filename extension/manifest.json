{
  "manifest_version": 3,
  "name": "rearview, honest self-view for video calls",
  "version": "0.1.0",
  "description": "A live mirror on a short delay. Glance over and see yourself as you were 3 seconds ago, exactly how the other person saw you.",
  "permissions": ["storage", "activeTab"],
  "background": { "service_worker": "background.js" },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "rearview",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/wc/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": ["mirror-core.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
